# EvalX API Server Configuration

# Database (PostgreSQL)
DATABASE_URL=postgres://evalx:evalx@localhost:5432/evalx

# Redis
REDIS_URL=redis://localhost:6379

# Kafka (Redpanda)
KAFKA_BROKERS=localhost:19092

# Server
PORT=3001
NODE_ENV=development

# LLM API Keys (Free tiers - no credit card required)
# Get Groq key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Get Gemini key at: https://ai.google.dev  
GEMINI_API_KEY=your_gemini_key_here
